# ── Application ───────────────────────────────────
PORT=3310
TZ=Europe/Paris

# ── MongoDB ───────────────────────────────────────
MONGO_USER=myapp
MONGO_PASS=CHANGE_ME_STRONG_PASSWORD
MONGO_DB_NAME=myapp
MONGO_URL=mongodb://${MONGO_USER}:${MONGO_PASS}@mongo:27017/${MONGO_DB_NAME}?authSource=admin

# ── Déploiement ───────────────────────────────────
# domain → reverse-proxy partagé, HTTPS automatique (nécessite un domaine)
# port   → Caddy intégré sur APP_PORT, HTTP uniquement (fonctionne avec une IP)
DEPLOY_MODE=domain

# Mode domain uniquement
COMPOSE_PROJECT_NAME=myapp
PROXY_PATH=../reverse-proxy

# Mode port uniquement
# APP_PORT=8080

# ── Host ──────────────────────────────────────────
# Domaine → HTTPS automatique via Let's Encrypt (ex: monapp.com)
# IP      → HTTP sur APP_PORT (ex: 51.178.42.10)
APP_HOST=TON_DOMAINE_OU_IP
# domain → https    port → http
APP_PROTOCOL=https

# ── CORS / URLs ───────────────────────────────────
# Mode domain :
CORS_ORIGIN=${APP_PROTOCOL}://${APP_HOST}
VITE_API_URL=${APP_PROTOCOL}://${APP_HOST}/api/
# Mode port :
# CORS_ORIGIN=${APP_PROTOCOL}://${APP_HOST}:${APP_PORT}
# VITE_API_URL=${APP_PROTOCOL}://${APP_HOST}:${APP_PORT}/api/

# ── JWT & Cookies ─────────────────────────────────
ACCESS_TOKEN_EXPIRATION_TIME=1h
# Générer avec : openssl rand -base64 64
ACCESS_TOKEN_SECRET=CHANGE_ME
REFRESH_TOKEN_SECRET=CHANGE_ME
COOKIE_SECRET=CHANGE_ME
